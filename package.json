{
  "name": "ash-run-84",
  "version": "0.1.0",
  "description": "Ash Run '84 turn-based tactics roguelite prototype built with Phaser and Electron.",
  "author": "OpenAI Codex",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "start": "node scripts/start-electron.mjs",
    "build": "node scripts/build.mjs",
    "check:unused": "knip --include dependencies,unlisted,exports,files",
    "sprites:sheets": "node scripts/generate-sprite-sheet-manifest.mjs",
    "sprites:variants": "node scripts/generate-sprite-variants.mjs",
    "test": "node --test",
    "test:playthrough": "node scripts/full-playthrough-check.mjs",
    "test:ui": "playwright test",
    "test:ui:update": "playwright test --update-snapshots",
    "package": "node scripts/build.mjs && electron-builder"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.12",
    "knip": "^6.6.0",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.ashrun84.game",
    "productName": "Ash Run '84",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  }
}

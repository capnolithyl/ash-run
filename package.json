{
  "name": "ash-run",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"node scripts/dev-server.mjs\" \"wait-on tcp:5173 && node scripts/start-electron.mjs\"",
    "start": "node scripts/start-electron.mjs",
    "build": "node scripts/build.mjs",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "vite": "^6.3.5",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.ashrun.game",
    "productName": "Ash Run",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": "nsis"
    }
  }
}
